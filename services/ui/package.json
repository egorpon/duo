        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.8.0",
        "next-themes": "^0.4.6",
        "ofetch": "^1.5.1",
        "radix-ui": "^1.4.3",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-hook-form": "^7.74.0",
        "react-router": "^7.14.1",
        "shadcn": "^4.2.0",
        "sonner": "^2.0.7",
