{
    "name": "Duo",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "lint": "eslint .",
        "format": "prettier --write \"**/*.{ts,tsx}\"",
        "format:check": "prettier --check \"**/*.{ts,tsx}\"",
