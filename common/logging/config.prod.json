{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
        "simple": {
            "format": "%(asctime)s %(levelname)-8s %(name)s %(message)s",
            "datefmt": "%Y-%m-%dT%H:%M:%S%z"
        },
        "color": {
            "()": "common.logging.formatters.ColorfulFormatter",
            "format": "%(asctime)s %(levelname)s %(name)s %(message)s",
            "datefmt": "%Y-%m-%dT%H:%M:%S%z"
        }
    },
    "filters": {
        "keyword": {
            "()": "common.logging.filters.KeywordLevelFilter",
            "filters": [
                {
                    "level": "INFO",
                    "keywords": ["grpc", "asyncio"]
                },
                {
                    "level": "WARNING",
                    "keywords": ["uvicorn.error"]
                }
            ]
        }
    },
    "handlers": {
        "stdout": {
            "class": "logging.StreamHandler",
            "formatter": "simple",
            "stream": "ext://sys.stdout",
            "filters": ["keyword"]
        }
    },
    "root": {
        "level": "DEBUG",
        "handlers": ["stdout"]
    },
    "loggers": {
        "gunicorn.error": {
            "level": "INFO",
            "handlers": ["stdout"],
            "propagate": false
        },
        "gunicorn.access": {
            "level": "INFO",
            "handlers": ["stdout"],
            "propagate": false
        }
    }
}

